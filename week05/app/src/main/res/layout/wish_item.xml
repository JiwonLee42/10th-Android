<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="12dp"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="184dp"
        android:layout_marginBottom="5dp">

        <ImageView
            android:id="@+id/wish_product_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background" />

        <ImageView
            android:id="@+id/wish_like_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="@drawable/ic_bg_circle_white"
            android:padding="6dp"
            android:src="@drawable/ic_favorite_border" />
    </FrameLayout>

    <TextView
        android:id="@+id/wish_product_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:text="Nike Air Force 1 '07"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/wish_product_sub_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:text="Women's Shoes"
        android:textColor="@color/gray"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/wish_product_color_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:text="5 Colours"
        android:textColor="@color/gray"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/wish_product_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="US$115"
        android:textSize="14sp" />

</LinearLayout>
