<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="314dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="6dp"
    android:paddingHorizontal="16dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/status_guide_line"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="24dp" />

    <ImageView
        android:id="@+id/recent_product_image"
        android:layout_width="0dp"
        android:layout_height="314dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_background"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/recent_product_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="Air Jordan XXXVI"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/recent_product_image"
        app:layout_constraintStart_toStartOf="@id/recent_product_image"
        app:layout_constraintEnd_toEndOf="@id/recent_product_image"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/recent_product_price"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="US$185"
        android:textSize="14sp"
        android:textColor="#888888"
        app:layout_constraintTop_toBottomOf="@id/recent_product_name"
        app:layout_constraintStart_toStartOf="@id/recent_product_name"
        app:layout_constraintEnd_toEndOf="@id/recent_product_name"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
